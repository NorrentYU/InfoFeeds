# Aggregate summarizer provider priority:
# 1. OpenAI-compatible API
# 2. Gemini
# 3. Local fallback

LLM_PROVIDER_NAME=
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# YouTube
YOUTUBE_COOKIES_FILE=./youtube.cookies.txt
YOUTUBE_INCLUDE_STREAM_TRANSCRIPTS=0

# X / CDP
X_CDP_ENDPOINT=http://127.0.0.1:9222
X_USERNAME=
X_PASSWORD=

# NotebookLM
NOTEBOOKLM_CDP_PORT=9233
NOTEBOOKLM_PROFILE=default

# Fulltest / aggregate
FULLTEST_X_MODE=production
AGGREGATE_USER_PROMPT=
REPORT_OUTPUT_DIR=./reports

# Schedule
SCHEDULE_TIME=09:30
SCHEDULE_TIMEZONE=UTC+8
SCHEDULE_LEAD_MINUTES=5
SCHEDULE_WINDOW_HOURS=24
